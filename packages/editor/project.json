{
	"$schema": "../../node_modules/nx/schemas/project-schema.json",
	"name": "editor",
	"projectType": "library",
	"root": "packages/editor",
	"sourceRoot": "packages/editor/src",
	"targets": {
		"prepare": {
			"inputs": ["{projectRoot}/**/*", "!{projectRoot}/.svelte-kit/**/*"],
			"outputs": ["{projectRoot}/.svelte-kit"],
			"executor": "nx:run-commands",
			"options": {
				"command": "bun --bun svelte-kit sync || echo ''",
				"cwd": "{projectRoot}"
			}
		},
		"build": {
			"executor": "nx:run-commands",
			"dependsOn": ["^build", "prepare"],
			"outputs": ["{projectRoot}/.svelte-kit", "{projectRoot}/build"],
			"options": {
				"command": "bun --bun svelte-package",
				"cwd": "{projectRoot}"
			}
		},
		"check": {
			"executor": "nx:run-commands",
			"options": {
				"command": "bun --bun svelte-check --tsconfig ./tsconfig.json",
				"cwd": "{projectRoot}"
			}
		},
		"lint": {
			"executor": "nx:run-commands",
			"options": {
				"commands": ["bun --bun prettier --check .", "bun --bun eslint ."],
				"cwd": "{projectRoot}"
			}
		},
		"lint:fix": {
			"executor": "nx:run-commands",
			"options": {
				"command": "bun --bun prettier . --write && bun --bun eslint . --fix",
				"cwd": "{projectRoot}"
			}
		}
	}
}
