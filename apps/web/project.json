{
	"name": "web",
	"projectType": "application",
	"root": "apps/web",
	"sourceRoot": "apps/web/src",
	"targets": {
		"prepare": {
			"executor": "nx:run-commands",
			"options": {
				"command": "bun --bun svelte-kit sync || echo ''",
				"cwd": "{projectRoot}"
			}
		},
		"build": {
			"executor": "nx:run-commands",
			"dependsOn": ["^build"],
			"outputs": ["{projectRoot}/.svelte-kit", "{projectRoot}/build"],
			"options": {
				"command": "bun --bun vite build",
				"cwd": "{projectRoot}"
			}
		},
		"dev": {
			"executor": "nx:run-commands",
			"options": {
				"command": "bun --bun vite dev",
				"cwd": "{projectRoot}"
			}
		},
		"preview": {
			"executor": "nx:run-commands",
			"dependsOn": ["build"],
			"options": {
				"command": "bun --bun vite preview",
				"cwd": "{projectRoot}"
			}
		},
		"check": {
			"executor": "nx:run-commands",
			"options": {
				"command": "bun --bun svelte-check --tsconfig ./tsconfig.json",
				"cwd": "{projectRoot}"
			}
		},
		"lint": {
			"executor": "nx:run-commands",
			"options": {
				"commands": ["bun --bun prettier --check .", "bun --bun eslint ."],
				"cwd": "{projectRoot}"
			}
		},
		"lint:fix": {
			"executor": "nx:run-commands",
			"options": {
				"command": "bun --bun prettier . --write && bun --bun eslint . --fix",
				"cwd": "{projectRoot}"
			}
		}
	}
}
