{
	"name": "@org/source",
	"version": "0.0.0",
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@nx/eslint-plugin": "22.7.5",
		"@types/node": "^25.9.3",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"nx": "22.7.5",
		"prettier": "^3.8.4",
		"prettier-plugin-svelte": "^4.1.0",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"typescript": "~6.0.3",
		"typescript-eslint": "^8.61.0"
	},
	"license": "MIT",
	"private": true,
	"scripts": {
		"dev": "bun nx run web:dev",
		"build": "bun nx run web:build",
		"preview": "bun nx run web:preview",
		"check": "bun nx run web:check",
		"check:root": "bunx tsc --noEmit -p tsconfig.json",
		"lint": "bun nx run web:lint",
		"lint:root": "bunx eslint prettier.config.ts eslint.config.ts",
		"format": "bun --bun prettier . --write",
		"format:check": "bun --bun prettier . --check",
		"prepare": "bun --bun nx run-many -t prepare"
	},
	"type": "module",
	"workspaces": [
		"apps/*"
	]
}
